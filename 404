<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Page Not Found — Ascovita</title>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🌿</text></svg>">

  <!-- Google Analytics -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-PSRK3R6L0Z"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-PSRK3R6L0Z');
    gtag('event', '404_error', { page_path: window.location.pathname });
  </script>

  <!-- GitHub Pages SPA redirect fix -->
  <!-- Converts /shop → /#shop so the main index.html handles it -->
  <script>
    (function() {
      var path = window.location.pathname;
      var search = window.location.search;

      // Map known URL paths to page names
      var pageMap = {
        '/shop': 'shop',
        '/products': 'shop',
        '/blog': 'blog',
        '/about': 'about',
        '/b2b': 'b2b',
        '/contact': 'contact',
        '/faq': 'faq',
        '/advisor': 'advisor',
        '/cart': 'cart',
        '/checkout': 'checkout',
      };

      var pageName = pageMap[path] || pageMap[path.replace(/\/$/, '')] || null;

      if (pageName) {
        // Redirect to index.html with hash
        window.location.replace('https://www.ascovita.com/#' + pageName);
      } else {
        // Unknown path — redirect to home after 4 seconds
        setTimeout(function() {
          window.location.replace('https://www.ascovita.com/');
        }, 4000);
      }
    })();
  </script>

  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      background: #f8fdf4;
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      text-align: center;
      padding: 24px;
    }
    .container {
      max-width: 480px;
    }
    .emoji { font-size: 5rem; margin-bottom: 20px; }
    h1 {
      font-size: 1.8rem;
      color: #2D5016;
      font-weight: 800;
      margin-bottom: 10px;
    }
    p {
      color: #666;
      font-size: 0.95rem;
      line-height: 1.6;
      margin-bottom: 24px;
    }
    .btn {
      display: inline-block;
      background: linear-gradient(135deg, #2D5016, #4a7c28);
      color: white;
      padding: 14px 32px;
      border-radius: 100px;
      text-decoration: none;
      font-weight: 700;
      font-size: 0.95rem;
      margin: 6px;
      transition: opacity 0.2s;
    }
    .btn:hover { opacity: 0.88; }
    .btn-outline {
      background: transparent;
      border: 2px solid #2D5016;
      color: #2D5016;
    }
    .redirecting {
      margin-top: 20px;
      font-size: 0.8rem;
      color: #999;
    }
    .links {
      margin-top: 32px;
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      justify-content: center;
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="emoji">🌿</div>
    <h1>Page Not Found</h1>
    <p>The page you're looking for doesn't exist or may have moved. Let's get you back on track!</p>

    <a href="https://www.ascovita.com/" class="btn">🏠 Go to Homepage</a>
    <a href="https://www.ascovita.com/#shop" class="btn btn-outline">🛍️ Browse Products</a>

    <div class="links">
      <a href="https://www.ascovita.com/#about" style="color:#2D5016;font-size:.85rem;text-decoration:none">About Us</a> ·
      <a href="https://www.ascovita.com/#contact" style="color:#2D5016;font-size:.85rem;text-decoration:none">Contact</a> ·
      <a href="https://www.ascovita.com/#faq" style="color:#2D5016;font-size:.85rem;text-decoration:none">FAQ</a> ·
      <a href="https://www.ascovita.com/#blog" style="color:#2D5016;font-size:.85rem;text-decoration:none">Blog</a>
    </div>

    <p class="redirecting">Redirecting you to homepage in 4 seconds...</p>
  </div>
</body>
</html>
